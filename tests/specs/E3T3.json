[
  {
    "name": "/cloudcover shows cloud cover buttons",
    "steps": [
      {
        "send": { "text": "/cloudcover" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Select cloud cover:" } }
        ]
      }
    ]
  },
  {
    "name": "Auto (20%) button stores selection and confirms",
    "steps": [
      {
        "send": { "text": "/cloudcover" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Select cloud cover:" } }
        ]
      },
      {
        "send": { "callback": "cc:auto" },
        "expect": [
          { "method": "answerCallbackQuery" },
          { "method": "sendMessage", "payload": { "text": "Cloud cover: Auto (20%)" } }
        ]
      }
    ]
  },
