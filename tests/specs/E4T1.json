[
  {
    "name": "/process queues job and sends processing message",
    "steps": [
      {
        "send": { "text": "/process" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Processing your request..." } }
        ]
      }
    ]
  },
  {
    "name": "/process queues job with session parameters",
    "steps": [
      {
        "send": { "text": "/search" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "What place would you like to search for?" } }
        ]
      },
      {
        "send": { "text": "London" },
        "expect": [
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "text": "/process" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Processing your request..." } }
        ]
      }
    ]
  }
]
