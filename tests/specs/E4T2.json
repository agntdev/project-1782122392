[
  {
    "name": "/preview without place shows guidance",
    "steps": [
      {
        "send": { "text": "/preview" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "No search parameters configured. Use /search first." } }
        ]
      }
    ]
  },
  {
    "name": "/preview without satellite API access shows error after search",
    "steps": [
      {
        "send": { "text": "/search" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "What place would you like to search for?" } }
        ]
      },
      {
        "send": { "text": "Berlin" },
        "expect": [
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "text": "/preview" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Preview images are not available right now. Please try again later." } }
        ]
      }
    ]
  }
]
